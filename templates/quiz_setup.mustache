{{!
    @template block_dixeo_tutor/quiz_setup

    Practice quiz setup panel (count, difficulty, topic, language).

    Example context (json):
    {
        "coursename": "Sample course",
        "counts": [
            {"value": 3, "active": false},
            {"value": 5, "active": true}
        ],
        "difficulty_easy_active": false,
        "difficulty_medium_active": true,
        "difficulty_hard_active": false,
        "topics": [
            {"key": "course", "label": "Entire course", "selected": true}
        ],
        "showlanguageselector": true,
        "languageselectid": "dixeo-quiz-setup-language",
        "languages": [
            {"code": "en", "name": "English", "selected": true}
        ]
    }
}}
<div class="dixeo-quiz-setup">
    <h5 class="dixeo-quiz-setup__title mb-2">{{#str}}quiz_setup_title, block_dixeo_tutor{{/str}}</h5>

    <label class="dixeo-quiz-setup__label small font-weight-bold mb-1">{{#str}}quiz_setup_count, block_dixeo_tutor{{/str}}</label>
    <div class="dixeo-quiz-setup__count-row mb-2" data-role="count-row">
        {{#counts}}
        <button type="button"
                class="btn btn-sm btn-outline-secondary mr-1 mb-1{{#active}} active{{/active}}"
                data-count="{{value}}">{{value}}</button>
        {{/counts}}
    </div>

    <label class="dixeo-quiz-setup__label small font-weight-bold mb-1">{{#str}}quiz_setup_difficulty, block_dixeo_tutor{{/str}}</label>
    <div class="dixeo-quiz-setup__diff-row mb-2" data-role="diff-row">
        <button type="button"
                class="btn btn-sm btn-outline-secondary mr-1 mb-1{{#difficulty_easy_active}} active{{/difficulty_easy_active}}"
                data-difficulty="easy">{{#str}}quiz_difficulty_easy, block_dixeo_tutor{{/str}}</button>
        <button type="button"
                class="btn btn-sm btn-outline-secondary mr-1 mb-1{{#difficulty_medium_active}} active{{/difficulty_medium_active}}"
                data-difficulty="medium">{{#str}}quiz_difficulty_medium, block_dixeo_tutor{{/str}}</button>
        <button type="button"
                class="btn btn-sm btn-outline-secondary mr-1 mb-1{{#difficulty_hard_active}} active{{/difficulty_hard_active}}"
                data-difficulty="hard">{{#str}}quiz_difficulty_hard, block_dixeo_tutor{{/str}}</button>
    </div>

    <label class="dixeo-quiz-setup__label small font-weight-bold mb-1">{{#str}}quiz_setup_topic, block_dixeo_tutor{{/str}}</label>
    <select class="form-control form-control-sm dixeo-quiz-setup__topic-select mb-2"
            data-role="topic-select"
            aria-label="{{coursename}}">
        {{#topics}}
        <option value="{{key}}"{{#selected}} selected{{/selected}}>{{label}}</option>
        {{/topics}}
    </select>

    {{> block_dixeo_tutor/setup_language_field }}

    <div class="dixeo-quiz-setup__actions">
        <button type="button" class="btn btn-primary btn-sm" data-action="start">{{#str}}quiz_setup_start, block_dixeo_tutor{{/str}}</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-action="cancel">{{#str}}quiz_setup_cancel, block_dixeo_tutor{{/str}}</button>
    </div>
</div>
