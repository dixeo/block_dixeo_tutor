{{!
    @template block_dixeo_tutor/teach_setup_loading

    Custom lesson setup panel while course hierarchy topics load.

    Example context (json):
    {
        "coursename": "Sample course",
        "topiclabel": "Topic",
        "loadingtext": "Loading topics…",
        "promptlabel": "Describe what you want to learn",
        "promptplaceholder": "For example: explain this topic in simpler terms…",
        "promptvalue": "",
        "startlabel": "Create lesson",
        "cancellabel": "Cancel",
        "startdisabled": true,
        "showlanguageselector": true,
        "languageselectid": "dixeo-teach-setup-language",
        "labelclass": "dixeo-tutor-setup__label dixeo-teach-setup__label",
        "selectclass": "dixeo-teach-setup__language-select",
        "languages": [
            {"code": "en", "name": "English", "selected": true}
        ]
    }
}}
<div class="dixeo-teach-setup dixeo-tutor-setup">
    <h5 class="dixeo-tutor-setup__title dixeo-teach-setup__title mb-2">{{#str}}teach_setup_title, block_dixeo_tutor{{/str}}</h5>

    <label class="dixeo-tutor-setup__label dixeo-teach-setup__label small font-weight-bold mb-1">{{topiclabel}}</label>
    {{> block_dixeo_tutor/setup_topic_loading }}

    <label class="dixeo-tutor-setup__label dixeo-teach-setup__label small font-weight-bold mb-1" for="dixeo-teach-setup-prompt">{{promptlabel}}</label>
    <textarea id="dixeo-teach-setup-prompt"
              class="form-control form-control-sm dixeo-teach-setup__prompt mb-2"
              data-role="learner-prompt"
              rows="4"
              placeholder="{{promptplaceholder}}"
              aria-label="{{promptlabel}}">{{promptvalue}}</textarea>

    {{> block_dixeo_tutor/setup_language_field }}

    {{> block_dixeo_tutor/setup_actions }}
</div>
