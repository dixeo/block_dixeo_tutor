<div id="dixeo-tutor" class="card border-0 shadow d-flex flex-column">
    <div class="card-header d-flex justify-content-between align-items-center bg-light px-3 py-2" id="dixeo-tutor-header">
        <span class="font-weight-bold dixeo-tutor-title">{{#str}}assistanttitle, block_dixeo_tutor{{/str}}</span>
        <span>
            <span class="dixeo-tutor-toggle">
                <i class="fa fa-chevron-down"></i>
            </span>
        </span>
    </div>
    <div class="card-body p-2 d-flex flex-column" id="dixeo-tutor-messages">
        <!-- Messages will be appended here. -->
    </div>
    <div class="card-footer p-2">
        <div class="d-flex">
            <textarea id="dixeo-tutor-input"
                      class="form-control"
                      placeholder="{{#str}}placeholder, block_dixeo_tutor{{/str}}"
                      aria-label="{{#str}}placeholder, block_dixeo_tutor{{/str}}" {{! Added aria-label }}
            ></textarea>
            <button id="dixeo-tutor-send" class="btn btn-primary px-2">
                <i class="fa fa-paper-plane" aria-hidden="true"></i>
                <span class="sr-only">{{#str}}send, block_dixeo_tutor{{/str}}</span>
            </button>
        </div>
    </div>
</div>
