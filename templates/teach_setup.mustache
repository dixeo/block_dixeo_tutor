{{!
    @template block_dixeo_tutor/teach_setup

    Custom lesson setup panel (topic, prompt, language).

    Example context (json):
    {
        "coursename": "Sample course",
        "topics": [
            {"key": "course", "label": "Entire course", "selected": true}
        ],
        "promptvalue": "Explain photosynthesis simply",
        "showlanguageselector": true,
        "languageselectid": "dixeo-teach-setup-language",
        "languages": [
            {"code": "en", "name": "English", "selected": true}
        ]
    }
}}
<div class="dixeo-teach-setup">
    <h5 class="dixeo-teach-setup__title mb-2">{{#str}}teach_setup_title, block_dixeo_tutor{{/str}}</h5>

    <label class="dixeo-teach-setup__label small font-weight-bold mb-1">{{#str}}teach_setup_topic, block_dixeo_tutor{{/str}}</label>
    <select class="form-control form-control-sm dixeo-teach-setup__topic-select mb-2"
            data-role="topic-select"
            aria-label="{{coursename}}">
        {{#topics}}
        <option value="{{key}}"{{#selected}} selected{{/selected}}>{{label}}</option>
        {{/topics}}
    </select>

    <label class="dixeo-teach-setup__label small font-weight-bold mb-1" for="dixeo-teach-setup-prompt">{{#str}}teach_setup_prompt, block_dixeo_tutor{{/str}}</label>
    <textarea id="dixeo-teach-setup-prompt"
              class="form-control form-control-sm dixeo-teach-setup__prompt mb-2"
              data-role="learner-prompt"
              rows="4"
              placeholder="{{#str}}teach_setup_prompt_placeholder, block_dixeo_tutor{{/str}}"
              aria-label="{{#str}}teach_setup_prompt, block_dixeo_tutor{{/str}}">{{promptvalue}}</textarea>

    {{> block_dixeo_tutor/setup_language_field }}

    <div class="dixeo-teach-setup__actions">
        <button type="button" class="btn btn-primary btn-sm" data-action="start" disabled>{{#str}}teach_setup_start, block_dixeo_tutor{{/str}}</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-action="cancel">{{#str}}teach_setup_cancel, block_dixeo_tutor{{/str}}</button>
    </div>
</div>
